# Copy to .env and fill in.
PORT=5300

# Postgres connection string.
# Local example: createdb banoyah_learn  then:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/banoyah_learn

# Secret used to sign admin/learner JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# Token lifetime
JWT_EXPIRES=7d

# ── Optional ────────────────────────────────────────────────────────────────
# In production, run the backend behind a reverse proxy over HTTPS.
# NODE_ENV=production   # set by ecosystem.config.js / pm2

# AI quiz generation is configured in the Settings UI (stored per-org, no env
# needed). These env vars only act as a fallback/override if you prefer to pin
# the provider at the host level:
# AI_PROVIDER=gemini
# AI_MODEL=
# AI_API_KEY=
