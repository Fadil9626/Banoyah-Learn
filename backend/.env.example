# Copy to .env and fill in.
PORT=5300

# Postgres connection string.
# Local example: createdb banoyah_learn  then:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/banoyah_learn

# Secret used to sign admin/learner JWTs. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# Token lifetime
JWT_EXPIRES=7d
